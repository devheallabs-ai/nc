# NC Lang — Environment Variables
#
# Copy this file to .env and fill in your values.
# All variables are optional — NC works out of the box without them.

# ═══════════════════════════════════════════════════════════
#  Installation & Paths
# ═══════════════════════════════════════════════════════════

# Set to "yes" to skip the interactive license prompt during install
# NC_ACCEPT_LICENSE="yes"

# Override default install directory
# NC_INSTALL_DIR="$HOME/.nc"

# Standard library location (set automatically by installer)
# NC_LIB_PATH="$HOME/.nc/lib"

# ═══════════════════════════════════════════════════════════
#  AI Provider (optional — for `ask AI` and `nc generate`)
# ═══════════════════════════════════════════════════════════

# External AI provider endpoint
# NC_AI_URL="https://api.openai.com/v1/chat/completions"
# NC_AI_KEY="your-api-key-here"
# NC_AI_MODEL="gpt-4o"

# Adapter preset (from nc_ai_providers.json)
# NC_AI_ADAPTER="chat"

# Generation parameters
# NC_AI_TEMPERATURE="0.7"
# NC_AI_MAX_TOKENS="1024"

# ═══════════════════════════════════════════════════════════
#  Server Runtime
# ═══════════════════════════════════════════════════════════

# Default port for `nc serve`
# PORT=8000

# Logging level: debug, info, warn, error
# NC_LOG_LEVEL="info"
