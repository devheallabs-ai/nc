{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Requests / sec",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(nc_requests_total[5m])",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(nc_errors_total[5m]) / rate(nc_requests_total[5m]) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "Active Connections",
      "type": "gauge",
      "targets": [
        {
          "expr": "nc_active_connections",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "up{job=\"nc\"}",
          "legendFormat": "status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(nc_requests_total[1m])",
          "legendFormat": "requests/sec"
        },
        {
          "expr": "rate(nc_errors_total[1m])",
          "legendFormat": "errors/sec"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "title": "Active Connections Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "nc_active_connections",
          "legendFormat": "active"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 7,
      "title": "Request Rate by Method",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(nc_requests_total[5m])",
          "legendFormat": "{{ method }} {{ path }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nc", "api", "ai"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "NC Service Dashboard",
  "uid": "nc-service-dashboard"
}
