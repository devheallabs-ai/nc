{
  "comments": { "lineComment": "//" },
  "brackets": [["[", "]"], ["(", ")"], ["{", "}"]],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "{{", "close": "}}" }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^.*:\\s*$",
    "decreaseIndentPattern": "^\\s*(otherwise|on error|finally).*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^.*:\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(otherwise|on error|finally)\\s*:.*$",
      "action": { "indent": "indent" }
    }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(to |define |configure|api|match|if |repeat |while |try|on event|every|middleware)",
      "end": "^\\s*$"
    }
  }
}
