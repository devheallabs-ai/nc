// NC Standard Library — subprocess
// Run external commands

service "nc.subprocess"
version "1.0.0"
// Status: Placeholder — implementation in progress
to run with command:
    purpose: "Run a shell command and get the output"
    respond with ""

to check with command:
    purpose: "Run a command and check if it succeeds"
    respond with true

to output with command:
    purpose: "Run a command and capture its output"
    respond with ""
